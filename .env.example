ALPACA_PAPER_KEY=your_paper_key_id_here
ALPACA_PAPER_SECRET=your_paper_secret_key_here

# IEX works on the basic data plan. Change to sip only after your Alpaca
# account has SIP entitlement.
MARKET_DATA_FEED=iex
MARKET_DATA_ADJUSTMENT=raw
TRAIL_PERCENT=8.0
DYNAMIC_TRAIL_ENABLED=1
DYNAMIC_TRAIL_VOL_MULTIPLE=3.0
MIN_TRAIL_PERCENT=6.0
MAX_TRAIL_PERCENT=15.0
EXIT_ON_SIGNAL_LOSS=0
TARGET_N_POSITIONS=3
MAX_ENTRY_RVOL=0.45
TARGET_POSITION_RVOL=0.15

# Optional later, only for live trading.
ALPACA_LIVE_KEY=your_live_key_id_here
ALPACA_LIVE_SECRET=your_live_secret_key_here
