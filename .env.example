ALPACA_PAPER_KEY=your_paper_key_id_here
ALPACA_PAPER_SECRET=your_paper_secret_key_here

# IEX works on the basic data plan. Change to sip only after your Alpaca
# account has SIP entitlement.
MARKET_DATA_FEED=iex
MARKET_DATA_ADJUSTMENT=raw
DATA_LOOKBACK_DAYS=320
BAR_CACHE_ENABLED=1
BAR_CACHE_DIR=./.cache/bars
BAR_CACHE_MAX_AGE_HOURS=18
TRAIL_PERCENT=8.0
DYNAMIC_TRAIL_ENABLED=1
DYNAMIC_TRAIL_VOL_MULTIPLE=3.0
MIN_TRAIL_PERCENT=6.0
MAX_TRAIL_PERCENT=15.0
EXIT_ON_SIGNAL_LOSS=0
TARGET_N_POSITIONS=5
STRATEGY_CAPITAL=2500
MAX_DEPLOYED_PCT=1.0
MAX_ENTRY_RVOL=0.55
TARGET_POSITION_RVOL=0.12
# Use -999 to disable; 0 requires not lagging SPY over 63 days.
MIN_RELATIVE_STRENGTH_63=0
MIN_DECISION_SCORE=10.25
SECTOR_RELATIVE_STRENGTH_ENABLED=1
MIN_SECTOR_RELATIVE_STRENGTH_63=0
REGIME_REQUIRE_ABOVE_SMA_200=1
REGIME_REQUIRE_BREADTH=0
REGIME_MIN_UNIVERSE_ABOVE_SMA_50=0.45
REGIME_MIN_UNIVERSE_ABOVE_SMA_200=0.40
REGIME_MIN_UNIVERSE_POSITIVE_MOMENTUM=0.40
REGIME_MAX_BENCHMARK_DRAWDOWN_63=0.10
REGIME_MAX_BENCHMARK_RVOL_20=0.25
DECISION_LOG_ENABLED=1
DECISION_LOG_DIR=./.cache/decision_logs

# Optional later, only for live trading.
ALPACA_LIVE_KEY=your_live_key_id_here
ALPACA_LIVE_SECRET=your_live_secret_key_here
